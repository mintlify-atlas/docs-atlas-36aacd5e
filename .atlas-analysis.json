  "keyFeatures": [
    "Full-featured file browser with directory navigation history and quick-access shortcuts",
    "MP3 player with playlist management, shuffle, loop, metadata display, and lyrics via Genius/Spotify APIs",
    "MP4/video player powered by LibVLC with seek, volume, and repeat controls",
    "Image editor with brightness/contrast/saturation, grayscale, sepia, crop, brush drawing, and GPS EXIF map view",
    "Data Fusion Arena: import from SQL Server, MariaDB, and PostgreSQL; visualize with charts",
    "Data Cleaner: multi-format file reader (CSV, Excel, JSON, XML, Word) with column-type inference and automatic cleaning",
    "Document/spreadsheet editor supporting CSV, XLSX, DOCX, PPTX, TXT, JSON, XML, and PDF",
    "Screen and audio recorder with optional webcam capture, powered by NAudio and FFMpeg"
  ],
